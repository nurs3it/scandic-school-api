// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          Int      @id @default(autoincrement())
  parentName  String
  grade       String
  language    String
  parentPhone String
  createdAt   DateTime @default(now())
}

model NotificationEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model InstagramPost {
  id        Int      @id @default(autoincrement())
  url       String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
