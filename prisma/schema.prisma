// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          Int      @id @default(autoincrement())
  parentName  String
  grade       String
  language    String
  parentPhone String
  createdAt   DateTime @default(now())
}

model NotificationEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model InstagramPost {
  id        Int      @id @default(autoincrement())
  url       String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  REJECTED
  SOLD
}

model MerchOrder {
  id            Int         @id @default(autoincrement())
  parentName    String
  childrenNames String
  phone         String
  items         Json
  total         Int
  status        OrderStatus @default(NEW)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model News {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  title          String
  description    String
  bannerUrl      String
  content        String
  author         String
  tags           String[] @default([])
  publishedAt    DateTime
  readingMinutes Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, publishedAt])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model MerchItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  image       String
  images      String[] @default([])
  category    String?
  inStock     Boolean  @default(true)
  sizes       String[] @default([])
  colors      String[] @default([])
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PaymentMethod {
  NONE
  KASPI_PHONE
  KASPI_QR
  BOTH
}

enum RegistrationStatus {
  NEW
  PAID
  CONFIRMED
  REJECTED
  CANCELLED
}

model Club {
  id               Int          @id @default(autoincrement())
  slug             String       @unique
  name             String
  shortDescription String
  description      String       @db.Text
  image            String
  ageRange         String?
  schedule         String?
  teacher          String?
  isActive         Boolean      @default(true)
  order            Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tournaments      Tournament[]

  @@index([isActive, order])
}

model Tournament {
  id                   Int       @id @default(autoincrement())
  slug                 String    @unique
  title                String
  shortDescription     String
  description          String    @db.Text
  bannerUrl            String
  ageGroup             String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?
  location             String?
  stages               Json      @default("[]")

  isFree        Boolean       @default(false)
  price         Int           @default(0)
  paymentMethod PaymentMethod @default(NONE)
  kaspiPhone    String?
  kaspiQrUrl    String?

  isActive           Boolean @default(true)
  isRegistrationOpen Boolean @default(true)
  order              Int     @default(0)

  clubId        Int?
  club          Club?                    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  registrations TournamentRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startDate])
  @@index([clubId])
}

model TournamentRegistration {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  participantName String
  parentName      String?
  phone           String
  email           String?
  grade           String?
  comment         String?

  receiptUrl  String?
  paymentNote String?

  status    RegistrationStatus @default(NEW)
  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId, status])
  @@index([createdAt])
}
