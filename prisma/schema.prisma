// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          Int      @id @default(autoincrement())
  parentName  String
  grade       String
  language    String
  parentPhone String
  createdAt   DateTime @default(now())
}

model NotificationEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model InstagramPost {
  id        Int      @id @default(autoincrement())
  url       String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  REJECTED
  SOLD
}

model MerchOrder {
  id            Int         @id @default(autoincrement())
  parentName    String
  childrenNames String
  phone         String
  items         Json
  total         Int
  status        OrderStatus @default(NEW)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model News {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  title          String
  description    String
  bannerUrl      String
  content        String
  author         String
  tags           String[] @default([])
  publishedAt    DateTime
  readingMinutes Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, publishedAt])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model MerchItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  image       String
  images      String[] @default([])
  category    String?
  inStock     Boolean  @default(true)
  sizes       String[] @default([])
  colors      String[] @default([])
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
